#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook for the skills repo.
# Validates SKILL.md frontmatter format.
#
# Install:  ln -sf ../../hooks/pre-commit .git/hooks/pre-commit

REPO_ROOT="$(git rev-parse --show-toplevel)"
errors=0

# Every skill directory must have a SKILL.md
for dir in "$REPO_ROOT"/*/; do
  name=$(basename "$dir")
  [ "$name" = "hooks" ] && continue
  if [ ! -f "$dir/SKILL.md" ]; then
    echo "error: $name/ exists but has no SKILL.md"
    errors=$((errors + 1))
  fi
done

# Validate each SKILL.md
for skill_md in "$REPO_ROOT"/*/SKILL.md; do
  [ ! -f "$skill_md" ] && continue
  name=$(basename "$(dirname "$skill_md")")

  # Frontmatter must be the very first line
  first_line=$(head -1 "$skill_md")
  if [ "$first_line" != "---" ]; then
    echo "error: $name/SKILL.md frontmatter must start at line 1 (found: $first_line)"
    errors=$((errors + 1))
    continue
  fi

  # Required fields
  fm_name=$(grep '^name:' "$skill_md" 2>/dev/null | head -1 | sed 's/^name: *//;s/"//g' || true)
  fm_desc=$(grep '^description:' "$skill_md" 2>/dev/null | head -1 || true)
  ver=$(grep '^  version:' "$skill_md" 2>/dev/null | head -1 | sed 's/^  version: *"//;s/"$//' || true)
  src=$(grep '^  source:' "$skill_md" 2>/dev/null | head -1 | sed 's/^  source: *"//;s/"$//' || true)

  [ -z "$fm_name" ] && echo "error: $name/SKILL.md missing name field" && errors=$((errors + 1))
  [ -n "$fm_name" ] && [ "$fm_name" != "$name" ] && echo "error: $name/SKILL.md name is '$fm_name', expected '$name'" && errors=$((errors + 1))
  [ -z "$fm_desc" ] && echo "error: $name/SKILL.md missing description field" && errors=$((errors + 1))
  [ -z "$ver" ] && echo "error: $name/SKILL.md missing metadata.version" && errors=$((errors + 1))
  [ -z "$src" ] && echo "error: $name/SKILL.md missing metadata.source" && errors=$((errors + 1))
done

if [ "$errors" -gt 0 ]; then
  echo ""
  echo "$errors error(s) — fix before committing"
  exit 1
fi
